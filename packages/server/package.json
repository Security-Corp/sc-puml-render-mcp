{
  "name": "sc-puml-render-mcp",
  "version": "0.0.1",
  "description": "MCP server that renders PlantUML diagrams inline in MCP-compatible chat clients (Claude, Codex).",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "sc-puml-render-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "tsc -p tsconfig.json && node test/faz1-smoke.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "plantuml",
    "diagram",
    "uml",
    "claude"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@plantuml/core": "1.2026.6",
    "@resvg/resvg-wasm": "2.6.2",
    "dejavu-fonts-ttf": "2.37.3",
    "jsdom": "22.1.0",
    "opentype.js": "1.3.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/jsdom": "28.0.3",
    "@types/node": "^20.0.0",
    "@types/opentype.js": "1.3.10",
    "typescript": "^5.5.0"
  }
}
